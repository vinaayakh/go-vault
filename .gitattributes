# Normalize line endings: store everything with LF in the repo so the
# pre-commit `mixed-line-ending --fix=lf` hook and Git agree on Windows.
* text=auto eol=lf

# Explicit LF for source/config that must stay LF even on checkout.
*.go      text eol=lf
*.mod     text eol=lf
*.sum     text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.json    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.md      text eol=lf
*.sh      text eol=lf
Makefile  text eol=lf
Dockerfile text eol=lf

# Windows scripts keep CRLF.
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf

# Binary / generated assets: never normalize or diff as text.
*.wasm    binary
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.pdf     binary
*.gz      binary
*.zip     binary

# Mark generated code so diffs/reviews collapse it.
*_gen.go        linguist-generated=true
*.gen.go        linguist-generated=true
web/src/api/**  linguist-generated=true
