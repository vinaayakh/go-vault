# Copy this file to .env and fill in real values. .env is gitignored.
# Never commit secrets to version control.

# HTTP server port (default: 8080).
PORT=8080

# PostgreSQL connection string for the application (least-privilege vault_app role).
# The superuser URL (vault_root) is only needed for running migrations — see Makefile.
DATABASE_URL=postgres://vault_app:apppassword@localhost:5432/vault?sslmode=disable

# Database URL for running migrations (needs superuser or DDL privileges).
DATABASE_SUPERUSER_URL=postgres://vault_root:devpassword@localhost:5432/vault?sslmode=disable

# Deployment environment. Only "dev" enables the X-Dev-User guard.
# Set to "prod" or omit entirely in any non-local environment.
APP_ENV=dev

# Temporary Phase 2 dev auth guard. Set to "on" to enable X-Dev-User header auth.
# Hard-disabled when APP_ENV != "dev". Remove both env vars before Phase 3.
DEV_AUTH=on
